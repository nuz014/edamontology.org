        <obo:namespace>topic</obo:namespace>
        <oboInOwl:hasExactSynonym>Structure analysis</oboInOwl:hasExactSynonym>
        <oboInOwl:hasDefinition>Topic concerning the curation, processing and analysis of the structure of biological molecules, typically proteins and nucleic acids and other macromolecules.</oboInOwl:hasDefinition>
        <oboInOwl:hasNarrowSynonym>Computational structural biology</oboInOwl:hasNarrowSynonym>
